    - target: {fileID: 655768082258851078, guid: 50a37129500543e62a3cb3eabe83741f, type: 3}
      propertyPath: m_text
      value: "\u041D\u0415 \u0417\u041D\u0410\u041C \u041A\u0410\u041A\u0412\u041E
        \u0421\u0415 \u0421\u041B\u0423\u0427\u0412\u0410... \u041D\u0415 \u0421\u041C\u042F\u0422\u0410\u0425,
        \u0427\u0415 \u0421\u042A\u0421\u0422\u041E\u042F\u041D\u0418\u0415\u0422\u041E
        \u041C\u0418 \u0415 \u0422\u041E\u041B\u041A\u041E\u0412\u0410 \u041A\u0420\u0418\u0422\u0418\u0427\u041D\u041E.
        \u0418\u0417\u0413\u041B\u0415\u0416\u0414\u0410, \u0427\u0415 \u0421\u042A\u041C
        \u0417\u0410\u041A\u041B\u042E\u0427\u0415\u041D \u0412 \u041D\u042F\u041A\u0410\u041A\u042A\u0412
        \"\u041C\u0415\u041D\u0422\u0410\u041B\u0415\u041D \u041A\u0410\u041F\u0410\u041D\"
        \u041D\u0410 \u0421\u041F\u041E\u041C\u0415\u041D\u0418\u0422\u0415 \u041C\u0418.
        \u041C\u041E\u0416\u0415 \u0411\u0418 \u0410\u041A\u041E \u0413\u0418 \u041F\u0420\u041E\u041C\u0415\u041D\u042F,
        \u0429\u0415 \u0423\u0421\u041F\u0415\u042F \u0414\u0410 \u0421\u0415 \u0418\u0417\u041C\u042A\u041A\u041D\u0410."
