  - time: 0.85
    functionName: ShowSubtitles
    data: "\u041C\u0418\u042F:\\n\u0412\u0438\u0436... \u0414\u043D\u0435\u0441 \u043F\u0440\u043E\u0441\u0442\u043E
      \u0431\u0435\u0448\u0435... \u043E\u0442\u0432\u0440\u0430\u0442\u0438\u0442\u0435\u043B\u043D\u043E.
