      \u0432 \u043A\u0430\u043A\u044A\u0432 \u0438\u0434\u0438\u043E\u0442 \u0441\u0435
      \u043F\u0440\u0435\u0432\u044A\u0440\u043D\u0430."
    objectReferenceParameter: {fileID: 0}
