    objectReferenceParameter: {fileID: 0}
    floatParameter: 0
    intParameter: 0
    messageOptions: 0
  - time: 0.8666667
    functionName: ShowSubtitles
    data: "\u0411\u041E\u0411\u0418:\\n\u0412\u0438\u0436 \u0437\u043D\u0430\u043C,
