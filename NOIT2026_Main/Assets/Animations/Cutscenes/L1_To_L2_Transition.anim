  - time: 4.3333335
    functionName: ShowSubtitles
    data: "\u041C\u0418\u042F:\\n\u0421\u044A\u0436\u0430\u043B\u044F\u0432\u0430\u043C,
      \u043B\u0435\u043A\u043E \u0437\u0430\u043A\u044A\u0441\u043D\u044F\u0445.
      \u0418\u043C\u0430\u0448\u0435 \u0433\u043E\u043B\u044F\u043C\u0430 \u043E\u043F\u0430\u0448\u043A\u0430
      \u0437\u0430 \u0431\u0430\u043D\u0438\u0447\u043A\u0438\u0442\u0435."
    objectReferenceParameter: {fileID: 0}
    floatParameter: 0
    intParameter: 0
    messageOptions: 0
  - time: 4.366667
    functionName: ShowSubtitles
    data: "\u0411\u041E\u042F\u041D:\\n\u041D\u0438\u0449\u043E, \u0438\u043C\u0430\u043C\u0435
      \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u043E \u0441\u043B\u0435\u0434\u0432\u0430\u0449\u0438\u044F
      \u0447\u0430\u0441, \u0442\u0430\u043A\u0430 \u0447\u0435 \u043D\u044F\u043C\u0430
      \u0434\u0430 \u0438\u043C\u0430 \u043F\u0440\u043E\u0431\u043B\u0435\u043C,
      \u0430\u043A\u043E \u0437\u0430\u043A\u044A\u0441\u043D\u0435\u0435\u043C."
    objectReferenceParameter: {fileID: 0}
    floatParameter: 0
    intParameter: 0
    messageOptions: 0
  - time: 6.633333
    functionName: ShowSubtitles
    data: "\u041C\u0418\u042F:\\n\u0414\u0430\u2026 \u0434\u043D\u0435\u0441 \u043B\u0438
      \u043D\u0438 \u0431\u044F\u0445\u0430 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0442\u0435
      \u043D\u043E\u0440\u043C\u0430\u0442\u0438\u0432\u0438? \u041F\u0438\u0441\u043D\u0430
      \u043C\u0438 \u043E\u0442 \u0442\u044F\u0445, \u043C\u043D\u043E\u0433\u043E
      \u0433\u0438 \u043C\u0440\u0430\u0437\u044F. "
    objectReferenceParameter: {fileID: 0}
    floatParameter: 0
    intParameter: 0
    messageOptions: 0
  - time: 6.75
    functionName: ShowSubtitles
    data: "\u041C\u0418\u042F:\\n\u041C\u0438\u0441\u043B\u044F, \u0447\u0435 \u0434\u0430. "
    objectReferenceParameter: {fileID: 0}
    floatParameter: 0
    intParameter: 0
    messageOptions: 0
  - time: 10.266666
    functionName: ShowSubtitles
    data: "\u041C\u0418\u042F:\\n\u0414\u043D\u0435\u0441\u043A\u0430 \u043A\u0430\u043A\u0432\u043E
      \u043D\u0430\u043F\u0440\u0430\u0432\u0438 \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430?
      \u0420\u0435\u0448\u0438 \u043B\u0438 7-\u043C\u0430? "
    objectReferenceParameter: {fileID: 0}
    floatParameter: 0
    intParameter: 0
    messageOptions: 0
  - time: 10.316667
    functionName: ShowSubtitles
    data: "\u0411\u041E\u042F\u041D:\\n\u0425\u043C\u2026 \u0430\u043C\u0438\u2026
      \u0433\u043E\u0440\u0435 - \u0434\u043E\u043B\u0443..."
    objectReferenceParameter: {fileID: 0}
    floatParameter: 0
    intParameter: 0
    messageOptions: 0
  - time: 10.366667
    functionName: ShowSubtitles
    data: "\u041C\u0418\u042F:\\n\u0413\u043E\u0440\u0435 - \u0434\u043E\u043B\u0443?
      \u041A\u0430\u043A \u043C\u0438\u0441\u043B\u0438\u0448, \u0447\u0435 \u0441\u0438
      \u0441\u0435 \u0441\u043F\u0440\u0430\u0432\u0438\u043B?"
    objectReferenceParameter: {fileID: 0}
    floatParameter: 0
    intParameter: 0
    messageOptions: 0
  - time: 10.4
    functionName: ShowSubtitles
    data: "\u0411\u041E\u042F\u041D:\\n\u0410\u043C\u0438.. \u043D\u0435 \u0437\u043D\u0430\u043C\u2026
      \u044A\u043C\u2026 \u043F\u0440\u0438\u0435\u043C\u043B\u0438\u0432\u043E? "
    objectReferenceParameter: {fileID: 0}
    floatParameter: 0
    intParameter: 0
    messageOptions: 0
  - time: 10.433333
    functionName: ShowSubtitles
    data: "\u041C\u0418\u042F:\\n\u0411\u043E\u0431\u0438, \u0437\u043D\u0430\u0435\u0448,
      \u0447\u0435 \u201C\u041F\u0440\u0438\u0435\u043C\u043B\u0438\u0432\u043E\u201D
      \u043D\u044F\u043C\u0430 \u0434\u0430 \u0442\u0438 \u043F\u043E\u043C\u043E\u0433\u043D\u0435
      \u0434\u0430 \u0437\u0430\u0432\u044A\u0440\u0448\u0438\u0448 \u0434\u043E\u0431\u0440\u0435.
      \u0422\u0440\u044F\u0431\u0432\u0430\u0442 \u0442\u0438 \u0434\u043E\u0431\u0440\u0438
      \u043E\u0446\u0435\u043D\u043A\u0438."
    objectReferenceParameter: {fileID: 0}
    floatParameter: 0
    intParameter: 0
    messageOptions: 0
  - time: 10.466666
    functionName: ShowSubtitles
    data: "\u0411\u041E\u042F\u041D\\n\u0417\u043D\u0430\u043C, \u043D\u043E \u0435
      \u0441\u043B\u043E\u0436\u043D\u043E\u2026"
    objectReferenceParameter: {fileID: 0}
    floatParameter: 0
    intParameter: 0
    messageOptions: 0
  - time: 10.5
    functionName: ShowSubtitles
    data: "\u041C\u0418\u042F:\\n\u041D\u044F\u043C\u0430 \u043B\u0435\u0441\u043D\u0438
      \u043D\u0435\u0449\u0430\u2026 \u041D\u043E \u043D\u0435 \u0442\u0440\u044F\u0431\u0432\u0430
      \u0434\u0430 \u0441\u0435 \u043E\u0442\u043A\u0430\u0437\u0432\u0430\u0448,
      \u0438\u043C\u0430\u0448 \u0434\u043E\u0441\u0442\u0430 \u043F\u043E\u0442\u0435\u043D\u0446\u0438\u0430\u043B
      \u0438 \u0435 \u043C\u0430\u043B\u043A\u043E \u0442\u044A\u0436\u043D\u043E
      \u0434\u0430 \u0433\u043B\u0435\u0434\u0430\u043C \u043A\u0430\u043A \u0433\u043E
      \u043F\u043E\u0445\u0430\u0431\u044F\u0432\u0430\u0448."
    objectReferenceParameter: {fileID: 0}
    floatParameter: 0
    intParameter: 0
    messageOptions: 0
  - time: 10.533334
    functionName: ShowSubtitles
    data: "\u0411\u041E\u042F\u041D:\\n\u041D\u0435 \u0437\u043D\u0430\u043C\u2026
      \u0414\u043E\u0440\u0438 \u0434\u0430 \u043D\u0430\u0443\u0447\u0430 \u0432\u0441\u0438\u0447\u043A\u043E
      \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E, \u043D\u0435
      \u043C\u0438\u0441\u043B\u044F, \u0447\u0435 \u043C\u043E\u0433\u0430 \u0434\u0430
      \u0441\u0435 \u0441\u043F\u0440\u0430\u0432\u044F \u0441 \u0442\u043E\u0432\u0430
      \u0434\u0430 \u0438\u0437\u0433\u0440\u0430\u0434\u044F \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435\u043D\u0430
      \u0418\u0422 \u043A\u0430\u0440\u0438\u0435\u0440\u0430\u2026"
    objectReferenceParameter: {fileID: 0}
    floatParameter: 0
    intParameter: 0
    messageOptions: 0
  - time: 10.566667
    functionName: ShowSubtitles
    data: "\u0411\u041E\u042F\u041D:\\n\u0414\u0430\u0436\u0435 \u043D\u0435 \u043C\u043E\u0433\u0430
      \u0434\u0430 \u0433\u043E\u0432\u043E\u0440\u044F \u0441 \u043E\u0441\u0442\u0430\u043D\u0430\u043B\u0438\u0442\u0435
      \u043E\u0442 \u043A\u043B\u0430\u0441\u0430\u2026 \u043A\u0430\u043A \u0431\u0438\u0445
      \u043C\u043E\u0433\u044A\u043B \u0434\u0430 \u0433\u043E\u0432\u043E\u0440\u044F
      \u0441 \u043D\u044F\u043A\u0430\u043A\u044A\u0432 \u043C\u0435\u043D\u0438\u0434\u0436\u044A\u0440
      \u043D\u0430 \u0418\u0422 \u043A\u043E\u043C\u043F\u0430\u043D\u0438\u044F\u2026 "
