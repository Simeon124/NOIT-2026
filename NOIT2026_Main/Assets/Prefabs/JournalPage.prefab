--- !u!114 &3083073763580294867
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 6480645153282847808}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 3c03565a49e1024818bec603408b48f1, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::InterludeNote
  noteUIElement: {fileID: 0}
  text: "\t\t\t25-\u0442\u0438 \u044E\u043D\u0438 2024 \u0433\u043E\u0434\u0438\u043D\u0430\n\n\u041D\u0430\u0439
    - \u043F\u043E\u0441\u043B\u0435 \u0443\u0431\u0435\u0434\u0438\u0445 \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u0438\u0442\u0435
    \u043C\u0438 \u0434\u0430 \u0441\u0438 \u0432\u0437\u0435\u043C\u0430 \u043D\u043E\u0432
    \u0420\u0410\u0411\u041E\u0422\u0415\u0429 \u041A\u0410\u041A\u0422\u041E \u0422\u0420\u042F\u0411\u0412\u0410
    \u043A\u043E\u043C\u043F\u044E\u0442\u044A\u0440 \u0437\u0430 \u0443\u0441\u043F\u0435\u0448\u043D\u0430\u0442\u0430
    \u043C\u0438 \u0443\u0447\u0435\u0431\u043D\u0430 \u0433\u043E\u0434\u0438\u043D\u0430.
    \u041F\u0440\u043E\u0446\u0435\u0441\u043E\u0440\u0430 \u0438 RAM-\u0442\u0430
    \u0433\u0438 \u0432\u0437\u0435\u0445 \u043D\u0430 \u0434\u043E\u0441\u0442\u0430
    \u0434\u043E\u0431\u0440\u0430 \u0446\u0435\u043D\u0430 \u0438 \u043E\u0442\u0434\u0435\u043B\u043D\u043E
    \u0441\u0438 \u0432\u0437\u0435\u0445 \u0443\u043F\u043E\u0442\u0440\u0435\u0431\u0435\u043D\u0430
    \u0432\u0438\u0434\u0435\u043E\u043A\u0430\u0440\u0442\u0430 \u0438 \u0441\u0433\u043B\u043E\u0431\u0438\u0445
    \u043C\u0430\u0448\u0438\u043D\u0430\u0442\u0430 \u0441\u0430\u043C. \u041D\u0435
    \u043C\u043E\u0433\u0430 \u0434\u0430 \u0440\u0430\u0437\u0431\u0435\u0440\u0430
    \u0437\u0430\u0449\u043E \u043D\u0430\u0448\u0438\u0442\u0435 \u0438\u043C\u0430\u0442
    \u0442\u043E\u043B\u043A\u043E\u0432\u0430 \u0433\u043E\u043B\u044F\u043C \u043F\u0440\u043E\u0431\u043B\u0435\u043C
    \u0441 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u0438\u0442\u0435 \u043C\u0438.
    \u0422\u043E\u0432\u0430 \u0435 \u043D\u0435\u0449\u043E, \u043A\u043E\u0435\u0442\u043E
    \u043E\u0431\u043E\u0436\u0430\u0432\u0430\u043C \u0438 \u0441 \u043A\u043E\u0435\u0442\u043E
    \u043D\u044F\u043C\u0430 \u0434\u0430 \u0441\u043F\u0440\u0430 \u0434\u0430 \u0441\u0435
    \u0437\u0430\u043D\u0438\u043C\u0430\u0432\u0430\u043C, \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E
    \u043E\u0442 \u0442\u044F\u0445\u043D\u043E\u0442\u043E \u043C\u043D\u0435\u043D\u0438\u0435.
    \u0421\u044A\u0449\u043E \u0442\u0430\u043A\u0430 \u043C\u0438 \u0434\u0430\u0434\u043E\u0445\u0430
    \u0441\u0442\u0430\u0440\u043E \u043F\u0438\u0430\u043D\u043E, \u043A\u043E\u0435\u0442\u043E
    \u0435 \u0431\u0438\u043B\u043E \u043D\u0430 \u043F\u0440\u0430\u0434\u044F\u0434\u043E
    \u043C\u0438 \u0438 \u043C\u0438\u0441\u043B\u044F, \u0447\u0435 \u0449\u0435
    \u043C\u0438 \u0445\u0430\u0440\u0435\u0441\u0430. \u0412\u044A\u043F\u0440\u0435\u043A\u0438
    \u0440\u0430\u0437\u043B\u0438\u0447\u0438\u044F\u0442\u0430 \u043D\u0438, \u043D\u0435\u0449\u0430\u0442\u0430
    \u0437\u0430 \u0441\u0435\u0433\u0430 \u0441\u0430 \u0434\u043E\u0431\u0440\u0435,
    \u043E\u0441\u043E\u0431\u0435\u043D\u043E \u0441 \u043D\u043E\u0432\u0438\u0442\u0435
    \u043C\u0438 \u043F\u0440\u0438\u0434\u043E\u0431\u0438\u0432\u043A\u0438."
  pageAudioSource: {fileID: 0}
  maxGlowIntensity: 3
  timeMultiplier: 4
