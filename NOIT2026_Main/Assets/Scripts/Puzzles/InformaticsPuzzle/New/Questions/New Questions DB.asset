    - AnswerText: "\u0423\u043F\u0440\u0430\u0432\u043B\u044F\u0432\u0430 \u0445\u0430\u0440\u0434\u0443\u0435\u0440"
      IsCorrect: 1
    - AnswerText: "\u0423\u043F\u0440\u0430\u0432\u043B\u044F\u0432\u0430 \u0441\u043E\u0444\u0442\u0443\u0435\u0440"
      IsCorrect: 0
    - AnswerText: "\u041F\u0430\u0437\u0438 \u043A\u043E\u043C\u043F\u044E\u0442\u044A\u0440\u0430
        \u043E\u0442 \u0432\u0438\u0440\u0443\u0441\u0438"
