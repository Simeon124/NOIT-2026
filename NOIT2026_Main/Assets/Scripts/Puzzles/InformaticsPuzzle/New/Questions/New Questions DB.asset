      IsCorrect: 1
    - AnswerText: "\u041F\u0430\u0437\u0438 \u0444\u0430\u0439\u043B\u043E\u0432\u0435"
      IsCorrect: 0
    - AnswerText: "\u0421\u0442\u0430\u0440\u0442\u0438\u0440\u0430 \u041E\u0421"
      IsCorrect: 0
  - Difficulty: 0
    QuestionText: "\u0426\u0435\u043B \u043D\u0430 \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u043E\u043D\u043D\u0430\u0442\u0430
