      m_Calls: []
  m_text: "\t\t\t30-\u0442\u0438 \u0430\u0432\u0433\u0443\u0441\u0442 2023 \u0433\u043E\u0434\u0438\u043D\u0430\n\n\u0423\u0441\u043F\u044F\u0445!
    \u0412\u043B\u044F\u0437\u043E\u0445 \u0432 \u041F\u0413\u041C\u0415\u0422\u0422
    \u0428\u0443\u043C\u0435\u043D! \u041D\u044F\u043C\u0430\u043C \u0442\u044A\u0440\u043F\u0435\u043D\u0438\u0435
    \u043D\u0430\u0439-\u043F\u043E\u0441\u043B\u0435 \u0434\u0430 \u0441\u044A\u043C
    \u0447\u0430\u0441\u0442 \u043E\u0442 \u043A\u043B\u0430\u0441 \u0441 \u0445\u043E\u0440\u0430,
    \u043A\u043E\u0438\u0442\u043E \u043C\u0438\u0441\u043B\u044F\u0442 \u043A\u0430\u0442\u043E
    \u043C\u0435\u043D. \u0420\u043E\u0434\u0438\u0442\u0435\u043B\u0438\u0442\u0435
    \u043C\u0438 \u0441\u0430 \u043F\u0440\u0438\u0442\u0435\u0441\u043D\u0435\u043D\u0438,
    \u0447\u0435 \u0449\u0435 \u0443\u0447\u0430 \u0432 \u201C\u0433\u043E\u043B\u0435\u043C\u0438\u044F
    \u0433\u0440\u0430\u0434\u201D, \u043D\u043E \u0430\u0437 \u043C\u0438\u0441\u043B\u044F,
    \u0447\u0435 \u0449\u0435 \u0441\u0435 \u0441\u043F\u0440\u0430\u0432\u044F.
    \u041E\u0447\u0430\u043A\u0432\u0430\u043D\u0438\u044F\u0442\u0430 \u043C\u0438
    \u043D\u0435 \u0441\u0430 \u0441\u0442\u0440\u0430\u0448\u043D\u043E \u0432\u0438\u0441\u043E\u043A\u0438,
    \u043D\u043E \u043D\u0435 \u0441\u0430 \u0438 \u0438\u0437\u043E\u0431\u0449\u043E
    \u043D\u0438\u0441\u043A\u0438. \u041D\u0430\u0438\u0441\u0442\u0438\u043D\u0430
    \u0441\u0435 \u043D\u0430\u0434\u044F\u0432\u0430\u043C \u0442\u043E\u0432\u0430
    \u0443\u0447\u0438\u043B\u0438\u0449\u0435 \u0434\u0430 \u043C\u0438 \u043F\u043E\u043C\u043E\u0433\u043D\u0435
    \u0434\u0430 \u0441\u0435 \u0440\u0435\u0430\u043B\u0438\u0437\u0438\u0440\u0430\u043C
    \u043A\u0430\u0442\u043E \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0442\u0438\u043A."
